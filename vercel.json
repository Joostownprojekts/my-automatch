{
  "version": 2,
  "regions": ["fra1"],
  "builds": [
    {
      "src": "api/search.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "App.jsx",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/search",
      "dest": "api/search.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
